<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="author" content="{{ config.author }}">
  <meta name="description" content="{{ config.subject }}">
  <title>{{ config.title }}</title>
  <style>{{ stylesheet | safe }}</style>
</head>
<body>
  <a class="skip-link" href="#guide-races">Skip to recommendations</a>

  <main class="screen-guide">
    <header class="hero">
      <div class="hero-kicker">Seattle 2026 Primary</div>
      <h1>Endorsement consensus guide</h1>
      <p class="hero-deck">A source-transparent view of progressive endorsements, with the
        Seattle Times shown separately for comparison.</p>
      <div class="hero-meta" aria-label="Guide metadata">
        <span>Election {{ guide.metadata.election_date }}</span>
        <span>{{ guide.metadata.published_race_count }} races</span>
        <span>{{ guide.metadata.captured_source_count }} represented sources · {{ guide.metadata.unavailable_source_count }} unavailable</span>
        <span>Data {{ guide.metadata.data_version }}</span>
      </div>
    </header>

    <section class="screen-controls" aria-label="Race filters">
      <label for="race-filter">Show races</label>
      <select id="race-filter">
        <option value="all">All Seattle ballot races</option>
        <optgroup label="Ballot sections">
        {% for section in guide.sections %}
        <option value="{{ section.id }}">{{ section.label }}</option>
        {% endfor %}
        </optgroup>
        <optgroup label="Districts and jurisdictions">
        {% for option in filter_options %}<option value="{{ option }}">{{ option }}</option>{% endfor %}
        </optgroup>
      </select>
      <p id="filter-status" role="status" aria-live="polite"></p>
    </section>

    <div id="guide-races" class="screen-sections">
      {% for section in guide.sections %}
      <section class="screen-section" data-filter-section="{{ section.id }}">
        <div class="section-heading">
          <p>Ballot section</p>
          <h2>{{ section.label }}</h2>
        </div>
        <div class="race-grid">
          {% for race in section.races %}
          <article class="race-card" data-publication-race-id="{{ race.id }}"
            aria-labelledby="race-label-{{ race.id }}"
            data-filter-tokens='{{ race.filter_tokens | tojson }}'>
            <div class="race-card-head">
              <div>
                <p class="race-office" id="race-label-{{ race.id }}"
                  data-display-role="race-label">{{ race.race_label }}</p>
                <h3 data-display-role="recommendation">{{ race.recommendation_label }}</h3>
              </div>
              <div class="consensus-lockup" aria-label="Consensus among endorsers: {% if race.percentage_whole is none %}not available{% else %}{{ race.percentage_label }}{% endif %}">
                <span>Consensus among endorsers</span>
                <strong data-display-role="share">{% if race.percentage_whole is none %}N/A{% else %}{{ race.percentage_label }}{% endif %}</strong>
              </div>
            </div>
            {% if race.percentage_whole is not none %}
            <div class="consensus-meter" role="img" aria-label="Consensus share {{ race.percentage_label }}">
              <span style="width: {{ race.percentage_whole }}%"></span>
            </div>
            {% endif %}
            <p class="support-line" data-display-role="support">{{ race.support_summary }}</p>
            {% for comparison in race.comparisons %}
            <p class="comparison comparison-{{ comparison.voter_tone }}" role="group"
              aria-label="{{ comparison.voter_accessible_label }}" data-display-role="comparison">
              <span>Seattle Times</span>
              <strong>{{ comparison.voter_label }}</strong>
            </p>
            {% endfor %}
            {% if race.grade == 'Insufficient' %}
            <div class="insufficient-note" role="note" data-display-role="insufficient-warning">
              Too few explicit endorsements to assess consensus reliably.</div>
            {% endif %}
            {% if race.endorsement_groups %}
            <details>
              <summary aria-label="View endorsements for {{ race.race_label }}">View endorsements</summary>
              <div class="endorsement-groups">
                {% for group in race.endorsement_groups %}
                <section class="endorsement-group" data-candidate-id="{{ group.candidate_id }}">
                  <h4>{{ group.candidate_label }}
                    <span>{{ group.source_count }} endorsing source{% if group.source_count != 1 %}s{% endif %}</span></h4>
                  <ul>
                    {% for endorser in group.endorsers %}
                    <li data-candidate-id="{{ group.candidate_id }}" data-source-id="{{ endorser.source_id }}">
                      <a href="{{ endorser.evidence_url }}">{{ endorser.source_name }}</a>
                      {% if endorser.co_endorsement %}<span class="co-endorsement">Co-endorsement</span>{% endif %}
                    </li>
                    {% endfor %}
                  </ul>
                </section>
                {% endfor %}
              </div>
            </details>
            {% endif %}
          </article>
          {% endfor %}
        </div>
      </section>
      {% endfor %}
    </div>

    <section class="methodology-screen" id="methodology">
      <section class="methodology-panel">
        <p class="eyebrow">Methodology</p>
        <h2>How the consensus works</h2>
        <ol class="process-list">
          {% for step in guide.methodology.process_steps %}<li>{{ step }}</li>{% endfor %}
        </ol>
      </section>
      <section class="methodology-panel">
        <h3>Read this guide carefully</h3>
        {% for note in guide.methodology.interpretation_notes %}<p>{{ note }}</p>{% endfor %}
        {% for limitation in guide.methodology.limitations %}<p>{{ limitation }}</p>{% endfor %}
      </section>
      <section class="methodology-panel screen-consensus-key">
        <h3>How to read consensus</h3>
        <p>The percentage is the leading choice's share of endorsement points among sources
          that explicitly endorsed in that race.</p>
        <p>The source count shows how much evidence is behind that percentage. Consensus
          measures agreement among endorsers, not candidate quality.</p>
      </section>
      <section class="methodology-panel screen-source-categories">
        <h3>Source categories</h3>
        {% for category in guide.methodology.source_categories %}<p><strong>{{ category.label }}</strong>
          - {{ category.source_ids | length }} sources</p>{% endfor %}
        <h3>Possible overlap groups</h3>
        {% if guide.methodology.source_overlap_groups %}
          {% for group in guide.methodology.source_overlap_groups %}<p><strong>{{ group.label }}</strong>
            — {{ group.source_ids | length }} sources. {{ group.description }}</p>{% endfor %}
        {% else %}<p>No possible overlap groups span multiple active sources.</p>{% endif %}
      </section>
      <section class="methodology-panel screen-audit-metadata">
        <h3>Build and audit details</h3>
        <p>Election {{ guide.metadata.election_date }} | Generated {{ guide.metadata.generated_at.isoformat() }}</p>
        <p>Data {{ guide.metadata.data_version }} | Code {{ guide.metadata.git_commit[:12] }}</p>
        <p>{{ guide.metadata.captured_source_count }} represented / {{ guide.metadata.source_count }} active sources | {{ guide.metadata.published_race_count }} races |
          {{ guide.metadata.unresolved_review_count }} unresolved reviews</p>
        <p><a href="{{ config.project_url }}">Project source and audit files</a></p>
      </section>
      <section class="methodology-panel screen-verification">
        <h3>Verify the guide</h3>
        <p>{{ guide.methodology.verification_instructions }}</p>
      </section>
    </section>
  </main>

  <div class="print-guide">
    {% macro print_race(race) %}
    <article class="print-race">
      <div class="print-race-title">{{ race.race_label }}</div>
      <div class="print-race-result">
        <strong>{{ race.recommendation_label }}</strong>
        {% if race.percentage_whole is none %}
        <div class="print-meter print-meter-na"><b class="print-meter-label"><span class="print-meter-text">N/A</span></b></div>
        {% else %}
        <div class="print-meter" style="--meter-fill: {{ race.percentage_whole }}%">
          <b class="print-meter-label"><span class="print-meter-text">{{ race.percentage_label }}</span></b>
        </div>
        {% endif %}
      </div>
      {% set print_warnings = concise_warning_labels(race) %}
      <div class="print-race-context">
        {% for comparison in race.comparisons %}<span class="print-comparison">
          <b class="print-times-pick print-times-pick-{{ comparison.voter_tone }}"><span class="print-times-status">{{ comparison.print_status_label }}</span><span class="print-times-separator"> · </span><span class="print-times-choice">{{ comparison.print_choice_label }}</span></b>
        </span>{% endfor %}
        <span class="print-support print-support-full">{{ race.support_summary }}</span>
        <span class="print-support print-support-compact">{{ race.explicit_endorsement_count }} endorsers</span>
        {% if print_warnings %}<b class="print-compact-warning">{{ print_warnings[0] }}</b>{% endif %}
      </div>
      {% if print_warnings %}
      <div class="print-race-notes">
        <span>{{ print_warnings | join(' / ') }}</span>
      </div>{% endif %}
    </article>
    {% endmacro %}
    <section class="print-page print-page-one">
      <header class="print-header">
        <div>
          <p>Seattle 2026 Primary</p>
          <h1>Endorsement consensus</h1>
        </div>
        <div class="print-header-meta">{{ guide.metadata.election_date }}<br>
          {{ guide.metadata.published_race_count }} races | {{ guide.metadata.captured_source_count }}/{{ guide.metadata.source_count }} sources represented</div>
      </header>
      <p class="print-intro">Progressive-source consensus. Seattle Times choices are comparison only.
        Too few explicit endorsements are labeled; no recommendation is made from insufficient evidence.</p>
      <div class="print-races">
        {% set print_midpoint = (guide.metadata.published_race_count + 1) // 2 %}
        {% for print_column in range(2) %}
        {% set print_start = 0 if print_column == 0 else print_midpoint %}
        {% set print_end = print_midpoint if print_column == 0 else guide.metadata.published_race_count %}
        {% set print_position = namespace(value=0) %}
        {% set displayed_section = namespace(id='') %}
        <div class="print-race-column">
          {% for section in guide.sections %}
          {% set section_first = print_position.value %}
            {% for race in section.races %}
              {% if print_position.value >= print_start and print_position.value < print_end %}
                {% if displayed_section.id != section.id %}
                <h2 class="print-section-title">{{ section.label }}{% if print_position.value > section_first %} — continued{% endif %}</h2>
                {% set displayed_section.id = section.id %}
                {% endif %}
                {{ print_race(race) }}
              {% endif %}
              {% set print_position.value = print_position.value + 1 %}
            {% endfor %}
          {% endfor %}
        </div>
        {% endfor %}
      </div>
      <footer>Verify details and evidence in the responsive guide at
        <a href="{{ config.project_url }}">{{ config.project_url }}</a></footer>
    </section>

    <section class="print-page print-page-two">
      <header class="method-header">
        <p>Methodology and sources</p>
        <h1>How to read this guide</h1>
        <div>This is endorsement aggregation, not independent candidate vetting.</div>
      </header>
      <div class="process-flow">
        {% for step in guide.methodology.process_steps %}
        <div><span>{{ loop.index }}</span><strong>{{ step }}</strong></div>
        {% endfor %}
      </div>
      <div class="method-grid">
        <div class="method-column">
          <section>
            <h2>How to read consensus</h2>
            <p>The percentage is the leading choice's share of exact endorsement points among
              sources that explicitly endorsed in that race.</p>
            <p>The source count gives the sample-size context. A divided result means lower
              agreement among endorsers, not a lower-quality candidate.</p>
          </section>
          <section>
            <h2>Interpretation</h2>
            <div class="concise-method-detail">
              {% for note in guide.methodology.interpretation_notes %}<p>{{ note }}</p>{% endfor %}
            </div>
            <p class="compact-method-note">Full interpretation notes are in the detailed edition.</p>
            <div class="times-key"><b>Seattle Times comparison:</b> green “Times agrees · choice”
              chips show the same choice; amber “Times differs · choice” chips show another choice;
              a neutral “Times · not covered” chip means the captured guide has no Times endorsement.</div>
          </section>
        </div>
        <div class="method-column">
          <section>
            <h2>Source categories</h2>
            {% for category in guide.methodology.source_categories %}
            <div class="category-row"><strong>{{ category.label }}</strong>
              <span>{{ category.source_ids | length }} source{% if category.source_ids | length != 1 %}s{% endif %}</span></div>
            {% endfor %}
            <h3>Possible overlap groups</h3>
            {% if guide.methodology.source_overlap_groups %}
              {% for group in guide.methodology.source_overlap_groups %}
              <p><strong>{{ group.label }}</strong> — {{ group.source_ids | length }} sources.</p>
              {% endfor %}
            {% else %}<p>No possible overlap groups span multiple active sources.</p>{% endif %}
            <p class="ld-source-rule"><strong>LD source rule:</strong> Seven LD organizations each
              count as one independent source on broader Seattle-ballot races they endorse;
              legislative contests count only for their own district.</p>
          </section>
          <section>
            <h2>Limitations</h2>
            <div class="concise-method-detail">
              {% for limitation in guide.methodology.limitations %}<p>{{ limitation }}</p>{% endfor %}
            </div>
            <p class="compact-method-note">Full limitations are in the detailed edition.</p>
          </section>
        </div>
      </div>
      <div class="print-metadata">
        <div><span>Election</span><strong>{{ guide.metadata.election_date }}</strong></div>
        <div><span>Generated</span><strong>{{ guide.metadata.generated_at.isoformat() }}</strong></div>
        <div><span>Data version</span><strong>{{ guide.metadata.data_version }}</strong></div>
        <div><span>Code</span><strong>{{ guide.metadata.git_commit[:12] }}</strong></div>
        <div><span>Represented sources</span><strong>{{ guide.metadata.captured_source_count }}</strong></div>
        <div><span>Unavailable sources</span><strong>{{ guide.metadata.unavailable_source_count }}</strong></div>
        <div><span>Published races</span><strong>{{ guide.metadata.published_race_count }}</strong></div>
        <div><span>Unresolved reviews</span><strong>{{ guide.metadata.unresolved_review_count }}</strong></div>
        <div><span>Project</span><strong><a href="{{ config.project_url }}">Source and audit files</a></strong></div>
      </div>
      <footer>{{ guide.methodology.verification_instructions }}</footer>
    </section>
  </div>

  <script>
  (() => {
    const edition = new URLSearchParams(window.location.search).get('edition');
    if (edition === 'compact' || edition === 'detailed') {
      document.documentElement.classList.add(`${edition}-edition`);
    }
    const centerPrintInk = () => {
      if (window.__disablePrintInkCentering) return;
      const printGuide = document.querySelector('.print-guide');
      if (!printGuide || getComputedStyle(printGuide).display === 'none') return;
      const context = document.createElement('canvas').getContext('2d');
      if (!context) return;
      const inkBounds = (element) => {
        const style = getComputedStyle(element);
        context.font = [style.fontStyle, style.fontWeight, style.fontSize, style.fontFamily]
          .join(' ');
        const text = [...element.childNodes]
          .filter((node) => node.nodeType === Node.TEXT_NODE)
          .map((node) => node.textContent).join('');
        const metrics = context.measureText(text);
        const marker = document.createElement('i');
        marker.style.cssText = 'display:inline-block;width:0;height:0;overflow:hidden;'
          + 'margin:0;padding:0;border:0;vertical-align:baseline';
        element.append(marker);
        const baseline = marker.getBoundingClientRect().top;
        marker.remove();
        return {
          top: baseline - metrics.actualBoundingBoxAscent,
          bottom: baseline + metrics.actualBoundingBoxDescent,
        };
      };
      const center = (container, elements, paddingTarget = container) => {
        paddingTarget.style.removeProperty('padding-top');
        paddingTarget.style.removeProperty('padding-bottom');
        const bounds = elements.map(inkBounds);
        const containerRect = container.getBoundingClientRect();
        const inkTop = Math.min(...bounds.map((bound) => bound.top));
        const inkBottom = Math.max(...bounds.map((bound) => bound.bottom));
        const imbalance = (inkTop - containerRect.top) - (containerRect.bottom - inkBottom);
        const offset = -imbalance / 2;
        const style = getComputedStyle(paddingTarget);
        paddingTarget.style.paddingTop =
          `${(Number.parseFloat(style.paddingTop) + offset).toFixed(3)}px`;
        paddingTarget.style.paddingBottom =
          `${(Number.parseFloat(style.paddingBottom) - offset).toFixed(3)}px`;
      };
      document.querySelectorAll('.print-meter').forEach((meter) => {
        const text = meter.querySelector('.print-meter-text');
        const label = meter.querySelector('.print-meter-label');
        if (text && label) center(meter, [text], label);
      });
      document.querySelectorAll('.print-times-pick').forEach((pill) => {
        center(pill, [...pill.querySelectorAll(':scope > span')]);
      });
      document.documentElement.dataset.printInkCentered = 'true';
    };
    const printMedia = window.matchMedia('print');
    const calibratePrintInk = () => {
      if (!printMedia.matches) return;
      if (document.fonts.status === 'loaded') {
        centerPrintInk();
      } else {
        document.fonts.ready.then(() => {
          if (printMedia.matches) centerPrintInk();
        });
      }
    };
    window.addEventListener('beforeprint', calibratePrintInk);
    printMedia.addEventListener('change', calibratePrintInk);
    calibratePrintInk();
    const select = document.querySelector('#race-filter');
    const status = document.querySelector('#filter-status');
    const cards = [...document.querySelectorAll('[data-publication-race-id]')];
    const sections = [...document.querySelectorAll('[data-filter-section]')];
    const applyFilter = () => {
      const token = select.value;
      let visible = 0;
      cards.forEach((card) => {
        const matches = token === 'all' || JSON.parse(card.dataset.filterTokens).includes(token);
        card.hidden = !matches;
        if (matches) visible += 1;
      });
      sections.forEach((section) => {
        section.hidden = ![...section.querySelectorAll('[data-publication-race-id]')]
          .some((card) => !card.hidden);
      });
      status.textContent = `${visible} races shown`;
    };
    select.addEventListener('change', applyFilter);
    applyFilter();
  })();
  </script>
</body>
</html>
