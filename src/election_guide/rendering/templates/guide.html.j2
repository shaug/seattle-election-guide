<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="author" content="{{ config.author }}">
  <meta name="description" content="{{ config.subject }}">
  <title>{{ config.title }}</title>
  <style>{{ stylesheet | safe }}</style>
</head>
<body>
  {% macro source_participation(source, compact=false) -%}
    {% if compact %}{{ source.endorsement_count }}{% if source.panel_role == 'comparison' %} picks{% endif %} · {{ source.split_endorsement_count }} split{% else %}{% if source.panel_role == 'comparison' %}{{ source.endorsement_count }} picks{% else %}{{ source.endorsement_count }} endorsements{% endif %} · {{ source.split_endorsement_count }} split{% endif %}
  {%- endmacro %}
  {% macro source_row(source, compact=false) -%}
    <div class="source-row source-row-{{ source.panel_role }}"
      data-publication-source-id="{{ source.id }}"
      data-source-category="{{ source.category }}"
      data-source-role="{{ source.panel_role }}">
      <a href="{{ source.evidence_url }}">{{ source.name }}</a>
      <span>{{ source_participation(source, compact) }}</span>
    </div>
  {%- endmacro %}
  {% macro coverage_gap_row(source, compact=false) -%}
    <section class="coverage-gap-row"
      data-coverage-gap-source-id="{{ source.id }}"
      data-coverage-gap-status="{{ source.coverage_gap_status }}">
      <div><a href="{{ source.evidence_url }}">{{ source.name }}</a>
        <strong>{% if source.coverage_gap_status == 'access_restricted' %}Official results inaccessible{% else %}No published results found{% endif %}</strong></div>
      {% if not compact %}<p>{{ source.coverage_gap_note }}</p>{% endif %}
    </section>
  {%- endmacro %}
  {% set contributing_sources = guide.sources | selectattr('contribution_status', 'equalto', 'contributing') | list %}
  {% set coverage_gap_sources = guide.sources | selectattr('contribution_status', 'equalto', 'coverage_gap') | list %}
  <a class="skip-link" href="#guide-races">Skip to recommendations</a>

  <main class="screen-guide">
    <header class="hero">
      <div class="hero-copy">
        <div class="hero-kicker">August 2026 Primary</div>
        <h1>Seattle Progressive Endorsement Guide</h1>
        <p class="hero-deck">Progressive endorsement agreement at a glance, with the
          Seattle Times shown separately for comparison.</p>
      </div>
      <div class="hero-meta" aria-label="Guide metadata">
        <span>Election {{ guide.metadata.election_date }}</span>
        <span>{{ guide.metadata.published_race_count }} races</span>
      </div>
    </header>

    <section class="screen-controls" aria-label="Race filters">
      <label for="race-filter">Show races</label>
      <select id="race-filter">
        <option value="all">All Seattle ballot races</option>
        <optgroup label="Ballot sections">
        {% for section in guide.sections %}
        <option value="{{ section.id }}">{{ section.label }}</option>
        {% endfor %}
        </optgroup>
        <optgroup label="Districts and jurisdictions">
        {% for option in filter_options %}<option value="{{ option }}">{{ option }}</option>{% endfor %}
        </optgroup>
      </select>
      <p id="filter-status" role="status" aria-live="polite"></p>
    </section>

    <div id="guide-races" class="screen-sections">
      {% for section in guide.sections %}
      <section class="screen-section" data-filter-section="{{ section.id }}">
        <div class="section-heading">
          <p>Ballot section</p>
          <h2>{{ section.label }}</h2>
        </div>
        <div class="race-grid">
          {% for race in section.races %}
          <article class="race-card" data-publication-race-id="{{ race.id }}"
            aria-labelledby="race-label-{{ race.id }}"
            data-filter-tokens='{{ race.filter_tokens | tojson }}'>
            <p class="race-office" id="race-label-{{ race.id }}"
              data-display-role="race-label">{{ race.race_label }}</p>
            <div class="screen-race-result">
              <h3 data-display-role="recommendation">{{ race.recommendation_label }}</h3>
              {% if race.percentage_whole is none %}
              <div class="screen-meter screen-meter-na" role="img" data-display-role="share"
                aria-label="{{ screen_share_accessible_label(race) }}">
                <strong>N/A</strong>
              </div>
              {% else %}
              <div class="screen-meter" style="--meter-fill: {{ race.percentage_whole }}%"
                role="img" data-display-role="share"
                aria-label="{{ screen_share_accessible_label(race) }}">
                <strong>{{ race.percentage_label }}</strong>
              </div>
              {% endif %}
            </div>
            <div class="screen-race-context">
              <div class="screen-comparisons">
                {% for comparison in race.comparisons %}
                <p class="comparison comparison-{{ comparison.voter_tone }}" role="group"
                  aria-label="{{ comparison.voter_accessible_label }}" data-display-role="comparison">
                  <strong class="comparison-status">{{ comparison.print_status_label }}</strong><span class="comparison-separator"> · </span><span class="comparison-choice">{{ comparison.print_choice_label }}</span>
                </p>
                {% endfor %}
              </div>
              <p class="support-line" data-display-role="support">{{ screen_support_summary(race) }}</p>
            </div>
            {% if race.grade == 'Insufficient' %}
            <div class="insufficient-note" role="note" data-display-role="insufficient-warning">
              Too few explicit endorsements to assess consensus reliably.</div>
            {% endif %}
            {% if race.endorsement_groups %}
            <details>
              <summary aria-label="View endorsements for {{ race.race_label }}">View endorsements</summary>
              <div class="endorsement-groups">
                {% for group in race.endorsement_groups %}
                <section class="endorsement-group" data-candidate-id="{{ group.candidate_id }}">
                  <h4>{{ group.candidate_label }}
                    <span>{{ group.source_count }} endorsing source{% if group.source_count != 1 %}s{% endif %}</span></h4>
                  <ul>
                    {% for endorser in group.endorsers %}
                    <li data-candidate-id="{{ group.candidate_id }}" data-source-id="{{ endorser.source_id }}">
                      <a href="{{ endorser.evidence_url }}">{{ endorser.source_name }}</a>
                      {% if endorser.co_endorsement %}<span class="co-endorsement">Co-endorsement</span>{% endif %}
                    </li>
                    {% endfor %}
                  </ul>
                </section>
                {% endfor %}
              </div>
            </details>
            {% endif %}
          </article>
          {% endfor %}
        </div>
      </section>
      {% endfor %}
    </div>

    <footer class="screen-footer">
      <div class="footer-summary">
        <div>
          <p class="eyebrow">About this guide</p>
          <h2>Agreement, not a candidate grade.</h2>
        </div>
        <p>Percentages show agreement among sources that explicitly endorsed in each race.
          The Seattle Times is a separate comparison signal.</p>
        <nav class="footer-actions" aria-label="Guide links">
          <a href="{{ config.pdf_filename }}">Printable PDF</a>
          <a href="mailto:seattle-elections@dobravoda.dev">Feedback?</a>
          <a href="{{ config.project_url }}">Source and audit files</a>
        </nav>
      </div>
      <details class="guide-notes" id="methodology">
        <summary><span>Methodology</span><span aria-hidden="true">+</span></summary>
        <div class="methodology-screen">
      <section class="methodology-panel screen-consensus-key">
        <h3>Agreement, not a grade</h3>
        <p>The percentage is the leading choice's share of endorsement points among sources
          that explicitly endorsed in that race.</p>
        <p>The source count is the sample behind the percentage. Neither number rates candidate quality.</p>
      </section>
      <section class="methodology-panel">
        <h3>What enters the count</h3>
        <p>Each organization has equal weight. Multi-candidate endorsements split one point;
          no endorsement and missing coverage do not enter the percentage.</p>
        <p>Legislative-district groups count on broader races they cover, but only their own
          district's legislative contests.</p>
      </section>
      <section class="methodology-panel">
        <h3>The Times is separate</h3>
        <p>Seattle Times choices are shown only for comparison and never add a vote to the
          progressive consensus.</p>
        <p>This guide aggregates endorsements; it is not independent candidate vetting.</p>
      </section>
      <section class="methodology-panel methodology-overlap">
        <h3>Related organizations</h3>
        {% if guide.methodology.source_overlap_groups %}
          {% for group in guide.methodology.source_overlap_groups %}<p><strong>{{ group.label }}</strong>
            — {{ group.source_ids | length }} sources. These relationships are disclosed, not deduplicated.</p>{% endfor %}
        {% else %}<p>No possible overlap groups span multiple active sources.</p>{% endif %}
        <p>Organizations may update endorsements after capture, and a voter's exact ballot depends on registration address.</p>
      </section>
        </div>
      </details>
      <details class="guide-notes" id="sources">
        <summary><span>Sources ({{ guide.metadata.contributing_source_count }})</span><span aria-hidden="true">+</span></summary>
        <div class="screen-source-directory">
          <div class="screen-source-heading">
            <div><p class="eyebrow">Evidence directory</p><h2>Sources contributing to this guide</h2></div>
            <p>Counts cover the {{ guide.metadata.published_race_count }} races shown. Split is the
              multi-candidate subset.</p>
          </div>
          <div class="screen-source-columns">
            {% for category in guide.methodology.source_categories %}
            <section class="screen-source-category">
              <h3 data-source-category="{{ category.category }}">{{ category.label }}</h3>
              {% for source in contributing_sources if source.category == category.category %}
                {{ source_row(source) }}
              {% endfor %}
            </section>
            {% endfor %}
          </div>
          {% if coverage_gap_sources %}
          <section class="screen-coverage-gaps">
            <div><p class="eyebrow">Research status</p><h2>Coverage gaps ({{ guide.metadata.coverage_gap_count }})</h2>
              <p>These organizations were investigated, but no usable published endorsement list
                was available. They do not contribute to consensus scores.</p></div>
            <div class="coverage-gap-columns">
              {% for source in coverage_gap_sources %}{{ coverage_gap_row(source) }}{% endfor %}
            </div>
          </section>
          {% endif %}
        </div>
      </details>
      <div class="screen-footer-meta">
        <span>Election {{ guide.metadata.election_date }} · Built {{ guide.metadata.generated_at.date().isoformat() }} · Data {{ guide.metadata.data_version }} · Code {{ guide.metadata.git_commit[:12] }}<br>
          Panel {{ guide.metadata.source_panel_id }} · {{ guide.metadata.source_panel_hash }}</span>
        <a class="detailed-footer-audit" href="{{ config.project_url }}">Source and audit files</a>
      </div>
    </footer>
  </main>

  <div class="print-guide">
    {% macro print_race(race) %}
    <article class="print-race">
      <div class="print-race-title">{{ race.race_label }}</div>
      <div class="print-race-result">
        <strong>{{ race.recommendation_label }}</strong>
        {% if race.percentage_whole is none %}
        <div class="print-meter print-meter-na"><b class="print-meter-label"><span class="print-meter-text">N/A</span></b></div>
        {% else %}
        <div class="print-meter" style="--meter-fill: {{ race.percentage_whole }}%">
          <b class="print-meter-label"><span class="print-meter-text">{{ race.percentage_label }}</span></b>
        </div>
        {% endif %}
      </div>
      {% set print_warnings = concise_warning_labels(race) %}
      <div class="print-race-context">
        {% for comparison in race.comparisons %}<span class="print-comparison">
          <b class="print-times-pick print-times-pick-{{ comparison.voter_tone }}"><span class="print-times-status">{{ comparison.print_status_label }}</span><span class="print-times-separator"> · </span><span class="print-times-choice">{{ comparison.print_choice_label }}</span></b>
        </span>{% endfor %}
        <span class="print-support print-support-full">{{ race.support_summary }}</span>
        <span class="print-support print-support-compact">{{ race.explicit_endorsement_count }} endorsers</span>
        {% if print_warnings %}<b class="print-compact-warning">{{ print_warnings[0] }}</b>{% endif %}
      </div>
      {% if print_warnings %}
      <div class="print-race-notes">
        <span>{{ print_warnings | join(' / ') }}</span>
      </div>{% endif %}
    </article>
    {% endmacro %}
    <section class="print-page print-page-one">
      <header class="print-header">
        <div>
          <p data-document-role="print-election-label">August 2026 Primary</p>
          <h1 data-document-role="print-title">Seattle Progressive Endorsement Guide</h1>
        </div>
        <div class="print-header-meta">{{ guide.metadata.election_date }}<br>
          {{ guide.metadata.published_race_count }} races · source details on page 2</div>
      </header>
      <p class="print-intro">Progressive-source consensus. Seattle Times choices are comparison only.
        Too few explicit endorsements are labeled; no recommendation is made from insufficient evidence.</p>
      <div class="print-races">
        {% set print_midpoint = (guide.metadata.published_race_count + 1) // 2 %}
        {% for print_column in range(2) %}
        {% set print_start = 0 if print_column == 0 else print_midpoint %}
        {% set print_end = print_midpoint if print_column == 0 else guide.metadata.published_race_count %}
        {% set print_position = namespace(value=0) %}
        {% set displayed_section = namespace(id='') %}
        <div class="print-race-column">
          {% for section in guide.sections %}
          {% set section_first = print_position.value %}
            {% for race in section.races %}
              {% if print_position.value >= print_start and print_position.value < print_end %}
                {% if displayed_section.id != section.id %}
                <h2 class="print-section-title">{{ section.label }}{% if print_position.value > section_first %} — continued{% endif %}</h2>
                {% set displayed_section.id = section.id %}
                {% endif %}
                {{ print_race(race) }}
              {% endif %}
              {% set print_position.value = print_position.value + 1 %}
            {% endfor %}
          {% endfor %}
        </div>
        {% endfor %}
      </div>
      <footer>Verify details and evidence in the responsive guide at
        <a href="{{ config.project_url }}">{{ config.project_url }}</a></footer>
    </section>

    <section class="print-page print-page-two">
      <header class="method-header">
        <p>Methodology and sources</p>
        <h1>How to read this guide</h1>
        <div>{{ guide.metadata.contributing_source_count }} contributing sources ·
          {{ guide.metadata.coverage_gap_count }} coverage gaps</div>
      </header>
      <div class="page-two-content">
        <div class="method-summary">
          <article>
            <h2>Read the meter</h2>
            <p><strong>The percentage is agreement, not a candidate grade.</strong> It is the
              leading choice's share among sources that explicitly endorsed in that race.</p>
            <p>The source count shows the sample behind that percentage.</p>
          </article>
          <article class="times-summary">
            <h2>Read the Times pill</h2>
            <p><b class="method-pill method-pill-agrees">Times agrees</b> same choice</p>
            <p><b class="method-pill method-pill-differs">Times differs</b> another choice</p>
            <p><b class="method-pill">Times · not covered</b> no captured pick</p>
          </article>
          <article>
            <h2>Counting and scope</h2>
            <p>Each organization has equal weight; multi-candidate endorsements split one point.
              No endorsement and missing coverage stay visible but do not enter the percentage.</p>
            <p>LD groups count on broader races they cover, but only their own district's
              legislative races. Your registration address determines your exact ballot.</p>
          </article>
        </div>

        <section class="source-panel">
          <div class="source-panel-heading">
            <div><p>Evidence directory</p><h2>Sources contributing to this guide</h2></div>
            <span>{{ contributing_sources | selectattr('panel_role', 'equalto', 'consensus') | list | length }} consensus ·
              {{ contributing_sources | selectattr('panel_role', 'equalto', 'comparison') | list | length }} Times comparison<br>
              Counts: endorsements/picks · split subset</span>
          </div>
          {% set source_midpoint = (contributing_sources | length + 1) // 2 %}
          <div class="source-columns">
            {% for source_column in range(2) %}
            {% set source_start = 0 if source_column == 0 else source_midpoint %}
            {% set source_end = source_midpoint if source_column == 0 else contributing_sources | length %}
            {% set displayed_category = namespace(id='') %}
            <div class="source-column">
              {% for source in contributing_sources[source_start:source_end] %}
                {% if displayed_category.id != source.category %}
                {% set category = guide.methodology.source_categories | selectattr('category', 'equalto', source.category) | first %}
                <h3 data-source-category="{{ source.category }}">{{ category.label }}</h3>
                {% set displayed_category.id = source.category %}
                {% endif %}
                {{ source_row(source, true) }}
              {% endfor %}
            </div>
            {% endfor %}
          </div>
          {% if coverage_gap_sources %}
          <section class="print-coverage-gaps">
            <div class="print-coverage-gap-heading"><h3>Coverage gaps</h3><span>Investigated; not counted in consensus</span></div>
            <div class="coverage-gap-columns">
              {% for source in coverage_gap_sources %}{{ coverage_gap_row(source, true) }}{% endfor %}
            </div>
          </section>
          {% endif %}
        </section>

        <div class="method-notes">
          <article>
            <h2>Overlap and limitations</h2>
            <p>{% if guide.methodology.source_overlap_groups %}{% for group in guide.methodology.source_overlap_groups %}<strong>{{ group.label }}</strong>
              ({{ group.source_ids | length }}){% if not loop.last %}; {% endif %}{% endfor %}.
              {% else %}No possible overlap groups span multiple active sources.
              {% endif %}
              These relationships are disclosed, not deduplicated; each separately governed source
              keeps one vote. Organizations may update endorsements after capture.</p>
          </article>
          <article>
            <h2>Verify before voting</h2>
            <p>{{ guide.methodology.verification_instructions }} This guide aggregates
              endorsements; it is not independent candidate vetting.</p>
          </article>
        </div>
      </div>
      <footer class="page-two-footer">
        <span>Election {{ guide.metadata.election_date }} · Built {{ guide.metadata.generated_at.date().isoformat() }} · Data {{ guide.metadata.data_version }} · Code {{ guide.metadata.git_commit[:12] }}</span>
        <span>Panel {{ guide.metadata.source_panel_version }} · {{ guide.metadata.source_panel_hash[:12] }} · {{ guide.metadata.published_race_count }} races · <a href="{{ config.project_url }}">Source and audit files</a></span>
      </footer>
    </section>
  </div>

  <script>
  (() => {
    const edition = new URLSearchParams(window.location.search).get('edition');
    if (edition === 'compact' || edition === 'detailed') {
      document.documentElement.classList.add(`${edition}-edition`);
    }
    if (edition === 'detailed') {
      document.querySelectorAll('.guide-notes').forEach(details => details.setAttribute('open', ''));
    }
    const centerPrintInk = () => {
      if (window.__disablePrintInkCentering) return;
      const printGuide = document.querySelector('.print-guide');
      if (!printGuide || getComputedStyle(printGuide).display === 'none') return;
      const context = document.createElement('canvas').getContext('2d');
      if (!context) return;
      const inkBounds = (element) => {
        const style = getComputedStyle(element);
        context.font = [style.fontStyle, style.fontWeight, style.fontSize, style.fontFamily]
          .join(' ');
        const text = [...element.childNodes]
          .filter((node) => node.nodeType === Node.TEXT_NODE)
          .map((node) => node.textContent).join('');
        const metrics = context.measureText(text);
        const marker = document.createElement('i');
        marker.style.cssText = 'display:inline-block;width:0;height:0;overflow:hidden;'
          + 'margin:0;padding:0;border:0;vertical-align:baseline';
        element.append(marker);
        const baseline = marker.getBoundingClientRect().top;
        marker.remove();
        return {
          top: baseline - metrics.actualBoundingBoxAscent,
          bottom: baseline + metrics.actualBoundingBoxDescent,
        };
      };
      const center = (container, elements, paddingTarget = container) => {
        paddingTarget.style.removeProperty('padding-top');
        paddingTarget.style.removeProperty('padding-bottom');
        for (let attempt = 0; attempt < 4; attempt += 1) {
          const bounds = elements.map(inkBounds);
          const containerRect = container.getBoundingClientRect();
          const inkTop = Math.min(...bounds.map((bound) => bound.top));
          const inkBottom = Math.max(...bounds.map((bound) => bound.bottom));
          const imbalance = (inkTop - containerRect.top) -
            (containerRect.bottom - inkBottom);
          if (Math.abs(imbalance) < .05) break;
          const offset = -imbalance / 2;
          const style = getComputedStyle(paddingTarget);
          paddingTarget.style.paddingTop =
            `${(Number.parseFloat(style.paddingTop) + offset).toFixed(3)}px`;
          paddingTarget.style.paddingBottom =
            `${(Number.parseFloat(style.paddingBottom) - offset).toFixed(3)}px`;
        }
      };
      document.querySelectorAll('.print-meter').forEach((meter) => {
        const text = meter.querySelector('.print-meter-text');
        const label = meter.querySelector('.print-meter-label');
        if (text && label) center(meter, [text], label);
      });
      document.querySelectorAll('.print-times-pick').forEach((pill) => {
        center(pill, [...pill.querySelectorAll(':scope > span')]);
      });
      document.documentElement.dataset.printInkCentered = 'true';
    };
    const printMedia = window.matchMedia('print');
    const calibratePrintInk = () => {
      if (!printMedia.matches) return;
      if (document.fonts.status === 'loaded') {
        centerPrintInk();
      } else {
        document.fonts.ready.then(() => {
          if (printMedia.matches) centerPrintInk();
        });
      }
    };
    window.addEventListener('beforeprint', calibratePrintInk);
    printMedia.addEventListener('change', (event) => {
      if (event.matches) {
        requestAnimationFrame(() => requestAnimationFrame(calibratePrintInk));
      }
    });
    calibratePrintInk();
    const select = document.querySelector('#race-filter');
    const status = document.querySelector('#filter-status');
    const cards = [...document.querySelectorAll('[data-publication-race-id]')];
    const sections = [...document.querySelectorAll('[data-filter-section]')];
    const applyFilter = () => {
      const token = select.value;
      let visible = 0;
      cards.forEach((card) => {
        const matches = token === 'all' || JSON.parse(card.dataset.filterTokens).includes(token);
        card.hidden = !matches;
        if (matches) visible += 1;
      });
      sections.forEach((section) => {
        section.hidden = ![...section.querySelectorAll('[data-publication-race-id]')]
          .some((card) => !card.hidden);
      });
      status.textContent = `${visible} races shown`;
    };
    select.addEventListener('change', applyFilter);
    applyFilter();
  })();
  </script>
</body>
</html>
